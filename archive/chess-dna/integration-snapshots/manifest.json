{
  "manifest_version": 3,
  "name": "Chess Review Free",
  "version": "0.1.5",
  "description": "Free post-game analysis overlay for Chess.com using a local Stockfish engine.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://www.chess.com/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "action": {
    "default_title": "Chess Review Free",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.chess.com/game/live/*",
        "https://www.chess.com/analysis/game/live/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "overlay.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "profile.html",
        "profile.js",
        "stats.js",
        "storage.js",
        "vendor-chess.js",
        "vendor-stockfish.js",
        "vendor-stockfish.wasm"
      ],
      "matches": [
        "https://www.chess.com/*"
      ]
    }
  ]
}
