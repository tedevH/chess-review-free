{
  "manifest_version": 3,
  "name": "Chess Analysis Studio",
  "version": "0.1.6",
  "description": "General-purpose local chess analysis with PGN input and optional game import.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_title": "Chess Analysis Studio",
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "web_accessible_resources": []
}
